# Virtual environment
.venv/
venv/
env/

# Git and GitHub
.git/
.github/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Testing
.pytest_cache/
.coverage
htmlcov/
tests/

# Environment files (secrets!)
.env
.env.*
!.env.example

# macOS
.DS_Store

# Archives and old code
archive/

# Terraform (not needed in container)
infra/

# Documentation
docs/
*.md
!README.md

# Data files (import separately)
data/

# S3-hosted images (served from S3 in production)
static/images/artists/
static/images/creating/
static/images/antiques/
static/images/home/

# Only ship scripts/etl/ — the admin UI shells out to these via
# run_etl_script() (Spotify refresh, Goodreads/Letterboxd/Boredom-Killer
# imports). Everything else under scripts/ is local dev tooling, one-off
# migrations, or sensitive admin utilities (password reset, AWS SSM
# parameter helper) that has no business in a long-running container.
scripts/*
!scripts/etl
