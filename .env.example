# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
FLASK_SECRET_KEY=your-secret-key-here-change-this-in-production

# Debug Mode (set to false in production)
FLASK_DEBUG=true

# Server Configuration (for development)
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Database Configuration
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://localhost/library_of_babble
# Or with authentication:
# DATABASE_URL=postgresql://username:password@localhost/library_of_babble

# Spotify API Configuration
# Get Client ID and Secret from: https://developer.spotify.com/dashboard/applications
# Get Username from: https://www.spotify.com/account/overview/ (under "Username")
SPOTIPY_CLIENT_ID=your-spotify-client-id
SPOTIPY_CLIENT_SECRET=your-spotify-client-secret
SPOTIPY_USERNAME=your-spotify-username
# Refresh token for headless ETL runs (admin "Refresh Spotify" button + CI).
# Obtain ONCE by running:  python scripts/utils/spotify_authorize.py
# Spotify does not rotate refresh tokens for the playlist-read-private
# scope, so this value remains valid indefinitely.
SPOTIPY_REFRESH_TOKEN=your-spotify-refresh-token
# Must match a redirect URI configured on your Spotify Developer dashboard.
# Only needed at authorization time; the ETL itself never opens a browser.
# As of 2025 Spotify rejects http://localhost — use http://127.0.0.1 instead.
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# TMDB (The Movie Database) API Configuration
# Get your API key from: https://www.themoviedb.org/settings/api
TMDB_API_BEARER_TOKEN=your-tmdb-bearer-token-here

# AWS S3 + CloudFront Configuration (optional)
# Leave empty for local development (serves from local /static folder)
# Set these to enable S3 uploads and CloudFront serving

# AWS Credentials (for uploading to S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name

# CloudFront URL for serving images (not the S3 URL)
# Example: https://d1abcdef012345.cloudfront.net
STATIC_STORAGE_URL=
